---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Daycare in West Adams & Mid-City | Wise Leaders Academy"
  description="Wise Leaders Academy is a safe, licensed, and loving home daycare in West Adams & Mid-City Los Angeles where Little Leaders grow. State License #197495535."
>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-badge">
        <span class="stars">★★★★★</span>
        <span>Rated 5 Stars by Parents &nbsp;·&nbsp; State License #197495535</span>
      </div>
      <h1 class="fade-up">
        <span class="hero-title-line1">The Best Start for Your Child</span>
        <em class="hero-title-line2">in West Adams & Mid-City</em>
      </h1>
      <p class="hero-sub fade-up delay-1">A safe, licensed, and loving home daycare where <strong>"Little Leaders"</strong> grow.</p>
      <div class="hero-btns fade-up delay-2">
        <a href="/contact" class="btn btn-primary">Schedule a Tour</a>
        <a href="/contact#tuition" class="btn btn-outline">Inquire About Tuition</a>
      </div>
    </div>
  </section>

  <!-- ===== TRUST PILLARS ===== -->
  <section class="pillars section-sm">
    <div class="container pillars-grid">
      <div class="pillar">
        <div class="pillar-icon">🛡️</div>
        <h3>Safety First</h3>
        <p>Secure facility with strict health protocols. State Licensed (#197495535) + CPR/First Aid certified.</p>
      </div>
      <div class="pillar">
        <div class="pillar-icon">💛</div>
        <h3>Low Teacher Ratios</h3>
        <p>Small group sizes (1:5 ratio) ensuring personalized love and attention for every child.</p>
      </div>
      <div class="pillar">
        <div class="pillar-icon">🌱</div>
        <h3>Play-Based Growth</h3>
        <p>A balanced curriculum of structured learning and outdoor play to build confidence and social skills.</p>
      </div>
    </div>
  </section>

  <!-- ===== WELCOME / ABOUT INTRO ===== -->
  <section class="welcome section">
    <div class="container welcome-inner">
      <div class="welcome-visual" aria-hidden="true">
        <div class="welcome-card welcome-card-1">
          <span class="wc-num">1:5</span>
          <span class="wc-label">Teacher-to-child ratio</span>
        </div>
        <div class="welcome-card welcome-card-2">
          <span class="wc-num">Ages 1–6</span>
          <span class="wc-label">Served</span>
        </div>
        <div class="welcome-card welcome-card-3">
          <span class="wc-num">⭐ 5.0</span>
          <span class="wc-label">Parent rating</span>
        </div>
        <img
          src="/brand/judy-campbell.jpg"
          alt="Judy Campbell, Program Director"
          class="welcome-img"
          loading="lazy"
        />
      </div>
      <div class="welcome-text">
        <h2>Welcome to Wise Leaders Academy</h2>
        <h3 class="welcome-sub">Hi, I'm Judy, Program Director.</h3>
        <p>At Wise Leaders Academy, we believe daycare should feel like an extension of your own family. We founded this academy to provide West Adams families with a space that balances <strong>educational structure</strong> with the <strong>warmth of a grandmother's care</strong>.</p>
        <p>We don't just "watch" your children; we empower them to express themselves, take healthy risks, and develop the confidence to become tomorrow's wise leaders.</p>
        <a href="/about" class="btn btn-primary" style="margin-top:24px;">Learn About Us</a>
      </div>
    </div>
  </section>

  <!-- ===== CURRICULUM ===== -->
  <section class="curriculum section" style="background:var(--green-pale);">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Daily Life</span>
        <h2>More Than Just Playtime</h2>
        <p class="section-intro">Our daily schedule blends structured learning with joyful discovery.</p>
      </div>
      <div class="curriculum-grid">
        <div class="curr-card">
          <img
            src="https://lirp.cdn-website.com/2a45263c/dms3rep/multi/opt/discovery-1920w.png"
            alt="Child doing arts and crafts — creative expression"
            loading="lazy"
          />
          <div class="curr-body">
            <h3>Creative Expression</h3>
            <p>Sensory play, arts & crafts, and music time to spark imagination and fine motor skills.</p>
          </div>
        </div>
        <div class="curr-card">
          <img
            src="https://lirp.cdn-website.com/2a45263c/dms3rep/multi/opt/IMG-20250922-WA0004-1920w.png"
            alt="Children playing outdoors in Wise Leaders Academy's secure backyard"
            loading="lazy"
          />
          <div class="curr-body">
            <h3>Outdoor Discovery</h3>
            <p>Daily fresh air in our secure, private backyard where children run, garden, and explore nature safely.</p>
          </div>
        </div>
        <div class="curr-card">
          <img
            src="https://lirp.cdn-website.com/2a45263c/dms3rep/multi/opt/IMG-20250922-WA0026-1920w.png"
            alt="Child working on early literacy activities"
            loading="lazy"
          />
          <div class="curr-body">
            <h3>Early Academics</h3>
            <p>Age-appropriate literacy, numeracy, and science activities that prepare your child for school success.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROGRAMS ===== -->
  <section class="programs section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Programs</span>
        <h2>Our Programs</h2>
        <p class="section-intro">Thoughtfully designed programs that cater to each developmental stage, ensuring every child receives the right balance of learning, play, and growth.</p>
      </div>
      <div class="programs-grid">
        <div class="program-card">
          <div class="program-badge">Ages 1–3</div>
          <h3>Toddler Program</h3>
          <p>Our toddler program focuses on foundational development through play-based learning and sensory exploration. A safe, nurturing environment where your little one develops social skills, creativity, and independence.</p>
          <ul class="highlights-list">
            <li>Play-based learning activities</li>
            <li>Creative arts and crafts</li>
            <li>Music and movement</li>
            <li>Early social development</li>
            <li>Potty training support</li>
            <li>Outdoor exploration time</li>
          </ul>
        </div>
        <div class="program-card program-card-featured">
          <div class="program-badge program-badge-amber">Ages 3–6</div>
          <h3>Preschool Program</h3>
          <p>Our preschool program combines structured learning with joyful discovery. Children develop pre-academic skills, enhance their ability to socialize, and build confidence in self-expression while preparing for kindergarten.</p>
          <ul class="highlights-list">
            <li>Pre-kindergarten curriculum</li>
            <li>Early literacy and numeracy</li>
            <li>Science exploration</li>
            <li>Character development</li>
            <li>Group collaboration skills</li>
            <li>Kindergarten readiness</li>
          </ul>
        </div>
      </div>
      <div style="text-align:center;margin-top:40px;">
        <a href="/contact" class="btn btn-primary">Schedule a Tour</a>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="testimonials section" style="background: var(--brown);">
    <div class="container">
      <div class="section-header" style="color:var(--cream);">
        <span class="eyebrow" style="background:rgba(255,255,255,0.15);color:var(--green-pale);">Families Love Us</span>
        <h2 style="color:var(--cream);">Loved by Local Families</h2>
        <p class="section-intro" style="color:var(--cream);">Don't just take our word for it. Here is what parents in West Adams are saying.</p>
      </div>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="stars">★★★★★</div>
          <p>"This daycare is awesome, and the kids are really learning. Anyone who needs a daycare should send their kids to Wise Leaders Academy; they really value education."</p>
          <cite>— Nima Sheel</cite>
        </div>
        <div class="review-card">
          <div class="stars">★★★★★</div>
          <p>"As first-time parents, we were nervous about daycares. The team here made the transition seamless, and my baby loves coming to school. The daily updates and communication give us such peace of mind."</p>
          <cite>— Alex & Gen C.</cite>
        </div>
        <div class="review-card">
          <div class="stars">★★★★★</div>
          <p>"Finding a daycare you can trust can be a stressful experience, but from the moment we met Judy and Leighton, we felt safe. They aren't just incredible caretakers — they're family."</p>
          <cite>— <a href="https://www.calvarychapelcrenshaw.com" target="_blank" rel="noopener">Calvary Chapel Crenshaw</a></cite>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA / TUITION GUIDE ===== -->
  <section class="cta-section section" id="tuition">
    <div class="container cta-inner">
      <div class="cta-text">
        <span class="eyebrow">Still looking?</span>
        <h2>Still looking for the perfect care?</h2>
        <p>Download our current <strong>Tuition Rates</strong> + our free guide: <em>"10 Questions Every Parent Should Ask Before Choosing a Daycare."</em></p>
      </div>
      <div class="cta-form-wrap">
        <form
          id="tuition-form"
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
          novalidate
        >
          <!-- NOTE: Replace YOUR_FORM_ID with your Formspree (or chosen) form ID -->
          <div class="form-group">
            <label for="tf-name">Name</label>
            <input type="text" id="tf-name" name="name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label for="tf-email">Email</label>
            <input type="email" id="tf-email" name="email" placeholder="your@email.com" required />
          </div>
          <div class="form-group">
            <label for="tf-phone">Phone</label>
            <input type="tel" id="tf-phone" name="phone" placeholder="(xxx) xxx-xxxx" />
          </div>
          <input type="hidden" name="_subject" value="Tuition Rates Request – Wise Leaders Academy" />
          <button type="submit" class="btn btn-amber" style="width:100%;justify-content:center;">
            Send Me the Guide
          </button>
          <p class="form-success" id="tuition-success" style="display:none;color:var(--green);font-weight:600;text-align:center;margin-top:12px;">
            ✅ We've received your request — check your email shortly!
          </p>
          <p class="form-error" id="tuition-error" style="display:none;color:#c0392b;text-align:center;margin-top:12px;">
            Oops, there was an error. Please try again later.
          </p>
        </form>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ---- Hero ---- */
.hero {
  position: relative;
  overflow: hidden;
  background: linear-gradient(
      rgba(0,0,0,0.6),
      rgba(0,0,0,0.6)
    ),
    url('/brand/homepage-hero.jpg');
  background-size: cover;
  background-position: center;
  padding: 100px 0 80px;
  min-height: 600px;
  display: flex;
  align-items: center;
}

.hero-title-line1 {
  display: inline-block;
  white-space: nowrap;
  /* Center handled by h1 flex container */
  margin: 0;
  line-height: 1.0;
}

.hero-title-line2 {
  display: block;
  font-size: 0.75em; /* 25% less than the main title size */
  white-space: nowrap;
  /* Center handled by h1 flex container */
  margin: 0;
  line-height: 1.0;
}

@media (max-width: 700px) {
  /* On small screens allow wrapping so the hero doesn't overflow horizontally. */
  .hero-title-line1, .hero-title-line2 { white-space: normal; }
}

.hero-inner {
  position: relative;
  max-width: 700px;
  margin: 0 auto;
  text-align: center;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--white);
  border: 1px solid rgba(0,151,178,0.2);
  border-radius: 50px;
  padding: 8px 16px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-muted);
  margin: 0 auto 28px;
  box-shadow: var(--shadow);
}

h1 {
  font-size: clamp(2.4rem, 6vw, 4rem);
  color: var(--brown);
  margin-bottom: 20px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1.05;
}
h1 em {
  font-style: italic;
  color: var(--green);
  display: block;
  line-height: 1.05;
}

.hero-sub {
  font-size: 1.15rem;
  color: #ffffff;
  max-width: 480px;
  margin: 0 auto 36px;
}

.hero-btns { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }

/* ---- Pillars ---- */
.pillars { border-top: 1px solid rgba(0,151,178,0.1); }
.pillars-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}

.pillar {
  background: var(--white);
  border-radius: var(--radius);
  padding: 32px 28px;
  box-shadow: var(--shadow);
  transition: transform 0.2s, box-shadow 0.2s;
}
.pillar:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
.pillar-icon { font-size: 32px; margin-bottom: 12px; }
.pillar h3 { font-size: 1.1rem; margin-bottom: 8px; }
.pillar p { font-size: 14px; color: var(--text-muted); }

/* ---- Welcome ---- */
.welcome-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}

.welcome-text h2 { font-size: 2rem; margin-bottom: 12px; }
.welcome-sub { font-size: 1.1rem; color: var(--green); margin-bottom: 20px; font-family: 'DM Sans', sans-serif; }
.welcome-text p { color: var(--text-muted); margin-bottom: 12px; }

.welcome-visual {
  position: relative;
  height: 380px;
}
.welcome-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: var(--radius);
  box-shadow: var(--shadow-lg);
}

.welcome-card {
  position: absolute;
  background: var(--white);
  border-radius: var(--radius-sm);
  padding: 14px 18px;
  box-shadow: var(--shadow-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  z-index: 2;
}
.welcome-card-1 { top: -16px; left: -24px; }
.welcome-card-2 { bottom: 32px; left: -24px; }
.welcome-card-3 { top: 40px; right: -20px; }
.wc-num { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; color: var(--green); }
.wc-label { font-size: 11px; color: var(--text-muted); font-weight: 500; }

/* ---- Section header ---- */
.section-header { text-align: center; max-width: 600px; margin: 0 auto 48px; }
.section-header h2 { font-size: 2rem; margin-bottom: 12px; }
.section-intro { color: var(--text-muted); }

/* ---- Curriculum ---- */
.curriculum-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}
.curr-card {
  background: var(--white);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
  transition: transform 0.2s, box-shadow 0.2s;
}
.curr-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
.curr-card img { width: 100%; height: 200px; object-fit: cover; }
.curr-body { padding: 24px; }
.curr-body h3 { font-size: 1.1rem; margin-bottom: 8px; }
.curr-body p { font-size: 14px; color: var(--text-muted); }

/* ---- Programs ---- */
.programs-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px;
  max-width: 860px;
  margin: 0 auto;
}

.program-card {
  background: var(--white);
  border: 2px solid var(--green-pale);
  border-radius: var(--radius);
  padding: 36px 32px;
  position: relative;
  transition: transform 0.2s, box-shadow 0.2s;
}
.program-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
.program-card-featured { border-color: var(--amber); }

.program-badge {
  display: inline-block;
  background: var(--green-pale);
  color: var(--green);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  padding: 4px 12px;
  border-radius: 50px;
  margin-bottom: 16px;
}
.program-badge-amber { background: var(--amber-light); color: #92670d; }

.program-card h3 { font-size: 1.4rem; margin-bottom: 12px; }
.program-card > p { font-size: 14px; color: var(--text-muted); margin-bottom: 20px; }

.highlights-list {
  list-style: none;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.highlights-list li {
  font-size: 13px;
  color: var(--text-muted);
  padding-left: 20px;
  position: relative;
}
.highlights-list li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: var(--green);
  font-weight: 700;
}

/* ---- Reviews ---- */
.reviews-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.review-card {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: var(--radius);
  padding: 32px 28px;
}
.review-card .stars { margin-bottom: 16px; }
.review-card p { font-size: 15px; color: rgba(253,248,240,0.9); line-height: 1.7; margin-bottom: 16px; }
.review-card cite { font-size: 13px; font-style: normal; font-weight: 600; color: var(--cream); }
.review-card cite a { color: var(--green-light); }

/* ---- CTA / Form ---- */
.cta-section { background: var(--green-pale); }
.cta-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.cta-text h2 { font-size: 1.9rem; margin-bottom: 16px; }
.cta-text p { color: var(--text-muted); }

.cta-form-wrap {
  background: var(--white);
  border-radius: var(--radius);
  padding: 36px;
  box-shadow: var(--shadow-lg);
}

.form-group { margin-bottom: 16px; }
.form-group label {
  display: block;
  font-weight: 600;
  font-size: 14px;
  margin-bottom: 6px;
  color: var(--text);
}
.form-group input, .form-group textarea {
  width: 100%;
  padding: 12px 16px;
  border: 1.5px solid #e0d8cc;
  border-radius: var(--radius-sm);
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  color: var(--text);
  background: var(--cream);
  transition: border-color 0.15s, box-shadow 0.15s;
  outline: none;
}
.form-group input:focus {
  border-color: var(--green);
  box-shadow: 0 0 0 3px rgba(0,151,178,0.12);
}

/* ---- Responsive ---- */
@media (max-width: 900px) {
  .pillars-grid, .curriculum-grid, .reviews-grid { grid-template-columns: 1fr; }
  .welcome-inner, .cta-inner { grid-template-columns: 1fr; gap: 40px; }
  .welcome-visual { height: 260px; }
  .programs-grid { grid-template-columns: 1fr; }
  .welcome-card-1, .welcome-card-2, .welcome-card-3 { display: none; }
}
</style>

<script>
const form = document.getElementById('tuition-form') as HTMLFormElement | null;
const success = document.getElementById('tuition-success');
const error = document.getElementById('tuition-error');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const data = new FormData(form);
  try {
    const res = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
    if (res.ok) {
      form.reset();
      if (success) success.style.display = 'block';
    } else {
      if (error) error.style.display = 'block';
    }
  } catch {
    if (error) error.style.display = 'block';
  }
});
</script>
