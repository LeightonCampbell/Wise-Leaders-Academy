---
import BaseLayout from '../layouts/BaseLayout.astro';

const web3AccessKey = (
  import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ||
  import.meta.env.WEB3FORMS_ACCESS_KEY ||
  ''
).trim();
---
<BaseLayout
  title="Daycare in West Adams & Mid-City | Wise Leaders Academy"
  description="Wise Leaders Academy is a safe, licensed, and loving home daycare in West Adams & Mid-City Los Angeles where Little Leaders grow. State License #197495535."
>

  <!-- ===== HERO (split layout, light playful frame — nursery-school reference) ===== -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-blob-bg"></div>
      <svg class="hero-wave" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 200" preserveAspectRatio="none" aria-hidden="true">
        <path
          fill="var(--green-pale)"
          fill-opacity="0.65"
          d="M0,120 C180,40 360,180 540,100 C720,20 900,160 1080,90 C1260,20 1380,100 1440,60 L1440,200 L0,200 Z"
        />
      </svg>
    </div>

    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="hero-kicker">Welcome to</p>
        <h1 id="hero-heading" class="hero-heading">
          <span class="hero-heading-line">Wise Leaders</span>
          <span class="hero-heading-line hero-heading-line--accent">Academy</span>
        </h1>
        <p class="hero-lead">
          A safe, licensed, and loving home daycare in <strong>West Adams &amp; Mid-City</strong> where
          <strong>Little Leaders</strong> grow through play, structure, and heart.
        </p>
        <div class="hero-actions">
          <a href="#still-looking" class="btn hero-btn-more">More info</a>
          <a href="/contact" class="btn hero-btn-tour" data-modal-purpose="tour">Schedule a tour</a>
        </div>
        <p class="hero-trust" role="group" aria-label="Parent rating and licensing">
          <span class="hero-trust-item">
            <svg class="hero-star" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path fill="#f07830" d="M12 2.2l2.6 5.3 5.8.8-4.2 4.1 1 5.8L12 15.9 5.8 19.2l1-5.8-4.2-4.1 5.8-.8L12 2.2z"/>
            </svg>
            <span>Rated 5 stars by parents</span>
          </span>
          <span class="hero-trust-item">
            <svg class="hero-license-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path
                fill="none"
                stroke="var(--green)"
                stroke-width="1.75"
                stroke-linejoin="round"
                d="M12 2.25 4.75 5.4V11c0 4.05 2.65 7.85 7.25 9.45 4.6-1.6 7.25-5.4 7.25-9.45V5.4L12 2.25z"
              />
              <path
                fill="none"
                stroke="var(--green)"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9.25 12.25 11.2 14.2 15.9 8.9"
              />
            </svg>
            <span>State License #197495535</span>
          </span>
        </p>
      </div>

      <div class="hero-visual">
        <div class="hero-blob">
          <img
            src="/brand/homepage-hero.jpg"
            alt="Children learning and playing at Wise Leaders Academy in Los Angeles"
            width="640"
            height="720"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TRUST PILLARS (visual language continues from hero) ===== -->
  <section class="pillars" aria-labelledby="pillars-heading">
    <div class="pillars-bg" aria-hidden="true"></div>
    <div class="container pillars-wrap">
      <h2 id="pillars-heading" class="pillars-heading">
        <span class="pillars-kicker">Why families choose us</span>
        <span class="pillars-title">The foundation every child deserves</span>
      </h2>
      <div class="pillars-grid">
        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg width="40" height="40" version="1.1" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Safety icon">
              <path fill="currentColor" d="m86.062 20.332-32.422-14.859c-2.2656-1.0469-5.0156-1.0469-7.2812 0l-32.422 14.859c-2.7656 1.2812-4.5625 4.0625-4.5625 7.1094v10.047c0 47.574 39.859 57.684 40.266 57.777 0.10938 0.03125 0.23438 0.046875 0.35938 0.046875s0.25-0.015625 0.35938-0.046875c0.40625-0.09375 40.266-10.203 40.266-57.777v-10.047c0-3.0469-1.7969-5.8281-4.5625-7.1094zm1.4375 17.156c0 43.184-33.375 53.527-37.5 54.652-4.125-1.125-37.5-11.469-37.5-54.652v-10.047c0-1.8281 1.0781-3.5 2.7344-4.2656l32.438-14.859c0.71875-0.34375 1.5312-0.51562 2.3281-0.51562s1.6094 0.17188 2.3281 0.51562l32.438 14.859c1.6562 0.76562 2.7344 2.4375 2.7344 4.2656z"/>
              <path fill="currentColor" d="m80.344 28.02-29.688-13.609c-0.42188-0.1875-0.89062-0.1875-1.3125 0l-29.688 13.609c-0.54688 0.26562-0.90625 0.8125-0.90625 1.4219v8.0469c0 34.121 23.516 45.293 30.719 47.918 0.17188 0.0625 0.34375 0.09375 0.53125 0.09375s0.35938-0.03125 0.53125-0.09375c7.2031-2.625 30.719-13.797 30.719-47.918v-8.0469c0-0.60938-0.35938-1.1562-0.90625-1.4219zm-11.406 15.918-18.75 18.75c-0.875 0.875-2.0625 1.375-3.3125 1.375s-2.4375-0.5-3.3125-1.375l-9.375-9.375c-0.89062 0.89062-1.375-2.0625-1.375-3.3125 0-1.2656 0.48438-2.4375 1.375-3.3281 1.7656-1.7656 4.8594-1.7656 6.625 0l6.0625 6.0625 15.438-15.438c1.7656-1.7656 4.8594-1.7656 6.625 0 0.89062 0.89062 1.375 2.0625 1.375 3.3125 0 1.2656-0.48438 2.4375-1.375 3.3281z"/>
            </svg>
          </div>
          <div class="pillar-body">
            <h3>Safety First</h3>
            <p>Secure facility with strict health protocols. State Licensed (#197495535) + CPR/First Aid certified.</p>
          </div>
        </div>
        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" width="40" height="40" role="img" aria-label="Low teacher ratios icon">
              <path
                fill="currentColor"
                d="m85.613 43.746c-3.7461-1.6289-7.9922-1.7031-11.793-0.20312 0.35547-4.8594-0.38281-9.7344-2.1562-14.273-2.0312-5.0938-6.1094-9.1094-11.234-11.062-5.1289-1.957-10.844-1.6719-15.754 0.77734-4.9102 2.4492-8.5703 6.8438-10.094 12.117-4.7305-2.7812-10.41-3.457-15.66-1.8594-5.2539 1.5977-9.5938 5.3242-11.973 10.27-2.3789 4.9492-2.5781 10.668-0.54688 15.766 7.6133 19.102 31.934 24.262 36.734 25.102l0.81641-4.6641c-4.3633-0.76172-26.469-5.4219-33.148-22.188v-0.003906c-1.6719-4.1992-1.3477-8.9336 0.88672-12.863 2.2344-3.9297 6.1367-6.6289 10.602-7.3398 4.4648-0.71094 9.0117 0.64844 12.355 3.6914l3.5938 3.2656 0.36328-4.8398-0.003907-0.003906c0.33203-4.5078 2.6992-8.6211 6.4297-11.176 3.7266-2.5547 8.418-3.2773 12.742-1.9609 4.3281 1.3164 7.8203 4.5273 9.4922 8.7266 0.875 2.207 1.4531 4.5195 1.7148 6.8789-1.4414-1.4883-3.1641-2.6758-5.0664-3.4883-3.7773-1.625-8.0469-1.6836-11.863-0.16406-3.8203 1.5234-6.8789 4.5-8.5039 8.2773-6.3047 14.656 4.1562 30.762 6.3164 33.844l4.7188 6.7227 7.6797-10.34c1.8711-2.5195 8.3906-11.91 10.762-23.383l0.003906 0.003906c3.9023-2.9297 9.2852-2.8672 13.117 0.14844 3.8359 3.0195 5.1602 8.2344 3.2344 12.719-5.3086 12.344-21.969 15.391-25.254 15.875l0.69141 4.6875c3.7227-0.55078 22.609-4.0312 28.914-18.691 1.625-3.7773 1.6836-8.0469 0.16016-11.863-1.5234-3.8203-4.5-6.8789-8.2773-8.5039zm-27.148 26.184-3.7695 5.0742-0.95312-1.3555c-1.9062-2.7148-11.156-16.902-5.8438-29.25 1.9609-4.5547 6.7734-7.1797 11.664-6.3633s8.5898 4.8672 8.9648 9.8086c-2.0352 10.707-8.3047 19.723-10.062 22.086z"
              />
            </svg>
          </div>
          <div class="pillar-body">
            <h3>Low Teacher Ratios</h3>
            <p>Small group sizes (1:5 ratio) ensuring personalized love and attention for every child.</p>
          </div>
        </div>
        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg width="40" height="40" version="1.1" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Play-based growth icon">
              <g fill="currentColor">
                <path d="m64.121 56.512 7.6797-8.5508c0.82812-0.92188 1.1016-2.1797 0.71094-3.3594-0.39062-1.1797-1.3398-2.0391-2.5586-2.3008l-11.219-2.3711-5.7617-9.9609c-1.2383-2.1484-4.7109-2.1484-5.9609 0l-5.7617 9.9609-11.211 2.3711c-1.2188 0.26172-2.1719 1.1211-2.5586 2.3008-0.37891 1.1914-0.12109 2.4414 0.71875 3.3594l7.6797 8.5508-1.1914 11.441c-0.12891 1.2383 0.39062 2.4102 1.3984 3.1406 0.60156 0.44141 1.3008 0.66016 2.0117 0.66016 0.48047 0 0.94922-0.10156 1.4102-0.30078l10.492-4.6836 10.488 4.6719c1.1406 0.51953 2.4219 0.37891 3.4219-0.35156 1.0117-0.73047 1.5312-1.9102 1.3984-3.1406zm-3.9102-1.2734 1.3086 12.551-11.52-5.1289-11.52 5.1289 1.3086-12.551-8.4297-9.3789 12.32-2.6094 6.3203-10.922 6.3203 10.941 12.32 2.6094z"/>
                <path d="m48.121 11.879v8.8594c0 1.0391 0.83984 1.8789 1.8789 1.8789s1.8789-0.83984 1.8789-1.8789v-8.8594c0-1.0391-0.83984-1.8789-1.8789-1.8789s-1.8789 0.83984-1.8789 1.8789z"/>
                <path d="m21.719 21.711c-0.73047 0.73047-0.73047 1.9219 0 2.6602l6.2617 6.2695c0.37109 0.37109 0.85156 0.55078 1.3281 0.55078 0.48047 0 0.96094-0.17969 1.3281-0.55078 0.73047-0.73047 0.73047-1.9219 0-2.6602l-6.2617-6.2695c-0.73438-0.73047-1.9258-0.73047-2.6562 0z"/>
                <path d="m22.621 50c0-1.0391-0.83984-1.8789-1.8789-1.8789h-8.8594c-1.043 0-1.8828 0.83984-1.8828 1.8789s0.83984 1.8789 1.8789 1.8789h8.8594c1.043 0 1.8828-0.83984 1.8828-1.8789z"/>
                <path d="m27.98 69.359-6.2617 6.2695c-0.73047 0.73047-0.73047 1.9219 0 2.6602 0.37109 0.37109 0.85156 0.55078 1.3281 0.55078 0.48047 0 0.96094-0.17969 1.3281-0.55078l6.2617-6.2695c0.73047-0.73047 0.73047-1.9219 0-2.6602-0.73828-0.73047-1.918-0.73047-2.6562 0z"/>
                <path d="m50 77.379c-1.0391 0-1.8789 0.83984-1.8789 1.8789v8.8594c0 1.0391 0.83984 1.8789 1.8789 1.8789s1.8789-0.83984 1.8789-1.8789v-8.8594c0-1.0391-0.83984-1.8789-1.8789-1.8789z"/>
                <path d="m72.02 69.359c-0.73047-0.73047-1.9219-0.73047-2.6602 0-0.73047 0.73047-0.73047 1.9219 0 2.6602l6.2695 6.2695c0.37109 0.37109 0.85156 0.55078 1.3281 0.55078 0.48047 0 0.96094-0.17969 1.3281-0.55078 0.73047-0.73047 0.73047-1.9219 0-2.6602z"/>
                <path d="m88.121 48.121h-8.8594c-1.0391 0-1.8789 0.83984-1.8789 1.8789s0.83984 1.8789 1.8789 1.8789h8.8594c1.0391 0 1.8789-0.83984 1.8789-1.8789s-0.83984-1.8789-1.8789-1.8789z"/>
                <path d="m72.02 30.641 6.2695-6.2695c0.73047-0.73047 0.73047-1.9219 0-2.6602-0.73047-0.73047-1.9219-0.73047-2.6602 0l-6.2695 6.2695c-0.73047 0.73047-0.73047 1.9219 0 2.6602 0.37109 0.37109 0.85156 0.55078 1.3281 0.55078 0.48438 0 0.96094-0.19141 1.332-0.55078z"/>
              </g>
            </svg>
          </div>
          <div class="pillar-body">
            <h3>Play-Based Growth</h3>
            <p>A balanced curriculum of structured learning and outdoor play to build confidence and social skills.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WELCOME / ABOUT INTRO ===== -->
  <section class="welcome section section-band section-band--light">
    <div class="container welcome-inner">
      <div class="welcome-visual" aria-hidden="true">
        <div class="welcome-card welcome-card-1">
          <span class="wc-num">1:5</span>
          <span class="wc-label">Teacher-to-child ratio</span>
        </div>
        <div class="welcome-card welcome-card-2">
          <span class="wc-num">Ages 1–6</span>
          <span class="wc-label">Served</span>
        </div>
        <div class="welcome-card welcome-card-3">
          <span class="wc-num">⭐ 5.0</span>
          <span class="wc-label">Parent rating</span>
        </div>
        <img
          src="/brand/judy-campbell.jpg"
          alt="Judy Campbell, Program Director"
          class="welcome-img"
          loading="lazy"
        />
      </div>
      <div class="welcome-text">
        <h2>Welcome to Wise Leaders Academy</h2>
        <h3 class="welcome-sub">Hi, I'm Judy, Program Director.</h3>
        <p>At Wise Leaders Academy, we believe daycare should feel like an extension of your own family. We founded this academy to provide West Adams families with a space that balances <strong>educational structure</strong> with the <strong>warmth of a grandmother's care</strong>.</p>
        <p>We don't just "watch" your children; we empower them to express themselves, take healthy risks, and develop the confidence to become tomorrow's wise leaders.</p>
        <a href="/about" class="btn btn-primary" style="margin-top:24px;">Learn About Us</a>
      </div>
    </div>
  </section>

  <!-- ===== CURRICULUM ===== -->
  <section class="curriculum section section-band section-band--mint">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Daily Life</span>
        <h2>More Than Just Playtime</h2>
        <p class="section-intro">Our daily schedule blends structured learning with joyful discovery.</p>
      </div>
      <div class="curriculum-grid">
        <div class="curr-card">
          <img
            src="https://lirp.cdn-website.com/2a45263c/dms3rep/multi/opt/discovery-1920w.png"
            alt="Child doing arts and crafts — creative expression"
            loading="lazy"
          />
          <div class="curr-body">
            <h3>Creative Expression</h3>
            <p>Sensory play, arts & crafts, and music time to spark imagination and fine motor skills.</p>
          </div>
        </div>
        <div class="curr-card">
          <img
            src="https://lirp.cdn-website.com/2a45263c/dms3rep/multi/opt/IMG-20250922-WA0004-1920w.png"
            alt="Children playing outdoors in Wise Leaders Academy's secure backyard"
            loading="lazy"
          />
          <div class="curr-body">
            <h3>Outdoor Discovery</h3>
            <p>Daily fresh air in our secure, private backyard where children run, garden, and explore nature safely.</p>
          </div>
        </div>
        <div class="curr-card">
          <img
            src="https://lirp.cdn-website.com/2a45263c/dms3rep/multi/opt/IMG-20250922-WA0026-1920w.png"
            alt="Child working on early literacy activities"
            loading="lazy"
          />
          <div class="curr-body">
            <h3>Early Academics</h3>
            <p>Age-appropriate literacy, numeracy, and science activities that prepare your child for school success.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROGRAMS ===== -->
  <section class="programs section section-band section-band--paper">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Programs</span>
        <h2>Our Programs</h2>
        <p class="section-intro">Thoughtfully designed programs that cater to each developmental stage, ensuring every child receives the right balance of learning, play, and growth.</p>
      </div>
      <div class="programs-grid">
        <div class="program-card">
          <div class="program-badge">Ages 1–3</div>
          <h3>Toddler Program</h3>
          <p>Our toddler program focuses on foundational development through play-based learning and sensory exploration. A safe, nurturing environment where your little one develops social skills, creativity, and independence.</p>
          <ul class="highlights-list">
            <li>Play-based learning activities</li>
            <li>Creative arts and crafts</li>
            <li>Music and movement</li>
            <li>Early social development</li>
            <li>Potty training support</li>
            <li>Outdoor exploration time</li>
          </ul>
        </div>
        <div class="program-card program-card-featured">
          <div class="program-badge program-badge-amber">Ages 3–6</div>
          <h3>Preschool Program</h3>
          <p>Our preschool program combines structured learning with joyful discovery. Children develop pre-academic skills, enhance their ability to socialize, and build confidence in self-expression while preparing for kindergarten.</p>
          <ul class="highlights-list">
            <li>Pre-kindergarten curriculum</li>
            <li>Early literacy and numeracy</li>
            <li>Science exploration</li>
            <li>Character development</li>
            <li>Group collaboration skills</li>
            <li>Kindergarten readiness</li>
          </ul>
        </div>
      </div>
      <div class="section-actions">
        <a href="/contact" class="btn btn-primary" data-modal-purpose="tour">Schedule a Tour</a>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="testimonials section section-band section-band--deep">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Families Love Us</span>
        <h2>Loved by Local Families</h2>
        <p class="section-intro">Don't just take our word for it. Here is what parents in West Adams are saying.</p>
      </div>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars" aria-hidden="true">⭐⭐⭐⭐⭐</div>
          <p>"This daycare is awesome, and the kids are really learning. Anyone who needs a daycare should send their kids to Wise Leaders Academy; they really value education."</p>
          <cite>— Nima Sheel</cite>
        </div>
        <div class="review-card">
          <div class="review-stars" aria-hidden="true">⭐⭐⭐⭐⭐</div>
          <p>"As first-time parents, we were nervous about daycares. The team here made the transition seamless, and my baby loves coming to school. The daily updates and communication give us such peace of mind."</p>
          <cite>— Alex & Gen C.</cite>
        </div>
        <div class="review-card">
          <div class="review-stars" aria-hidden="true">⭐⭐⭐⭐⭐</div>
          <p>"Finding a daycare you can trust can be a stressful experience, but from the moment we met Judy and Leighton, we felt safe. They aren't just incredible caretakers — they're family."</p>
          <cite>— <a href="https://www.calvarychapelcrenshaw.com" target="_blank" rel="noopener">Calvary Chapel Crenshaw</a></cite>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA / TUITION GUIDE ===== -->
  <section class="cta-section section section-band section-band--mint" id="still-looking">
    <div class="container cta-inner">
      <div class="cta-text">
        <h2>Still looking for the perfect care?</h2>
        <p>Download our current <strong>Tuition Rates</strong> + our free guide: <em>"10 Questions Every Parent Should Ask Before Choosing a Daycare."</em></p>
      </div>
      <div class="cta-form-wrap surface-panel">
        <form
          id="tuition-form"
          action="https://api.web3forms.com/submit"
          method="POST"
          novalidate
        >
          <input type="hidden" name="access_key" value={web3AccessKey} />
          <div class="form-group">
            <label for="tf-name">Name</label>
            <input type="text" id="tf-name" name="name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label for="tf-email">Email</label>
            <input type="email" id="tf-email" name="email" placeholder="your@email.com" required />
          </div>
          <div class="form-group">
            <label for="tf-phone">Phone</label>
            <input type="tel" id="tf-phone" name="phone" placeholder="(xxx) xxx-xxxx" />
          </div>
          <input type="hidden" name="subject" value="Tuition Rates Request – Wise Leaders Academy" />
          <button type="submit" class="btn btn-amber" style="width:100%;justify-content:center;">
            Send Me the Guide
          </button>
          <p class="form-success" id="tuition-success" style="display:none;color:var(--green);font-weight:600;text-align:center;margin-top:12px;">
            ✅ We've received your request — check your email shortly!
          </p>
          <p class="form-error" id="tuition-error" style="display:none;color:#c0392b;text-align:center;margin-top:12px;">
            Oops, there was an error. Please try again later.
          </p>
        </form>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ---- Hero (light split: copy + organic image frame + bottom wave) ---- */
.hero {
  position: relative;
  overflow: hidden;
