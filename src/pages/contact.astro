---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Schedule a Tour | Wise Leaders Academy | Contact Us"
  description="Get in touch with Wise Leaders Academy. Schedule a tour, ask about enrollment, or inquire about tuition for our licensed daycare in West Adams, Los Angeles."
>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Get In Touch</span>
      <h1>We'd love to hear<br />from you.</h1>
      <p class="page-hero-sub">Fill out the form below and we will get back to you promptly.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">

      <!-- FORM -->
      <div class="contact-form-wrap">
        <h2>Send Us a Message</h2>
        <!--
          FORM SETUP INSTRUCTIONS
          ────────────────────────
          Choose a free form service (pick one):

          Option A — Formspree (recommended, free tier: 50 submissions/month)
            1. Sign up at https://formspree.io
            2. Create a new form → copy the endpoint URL
            3. Replace action="https://formspree.io/f/YOUR_FORM_ID" below

          Option B — Web3Forms (free, unlimited)
            1. Sign up at https://web3forms.com
            2. Get your access key
            3. Change action to "https://api.web3forms.com/submit"
            4. Add: <input type="hidden" name="access_key" value="YOUR_KEY" />

          Option C — Netlify Forms (if deploying on Netlify)
            1. Add netlify attribute: <form name="contact" method="POST" data-netlify="true">
            2. Add: <input type="hidden" name="form-name" value="contact" />
            3. No action URL needed — Netlify handles it automatically
        -->
        <form
          id="contact-form"
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
          novalidate
        >
          <input type="hidden" name="_subject" value="Contact Form – Wise Leaders Academy" />

          <div class="form-row">
            <div class="form-group">
              <label for="c-name">Name <span aria-hidden="true">*</span></label>
              <input type="text" id="c-name" name="name" placeholder="Your full name" required />
            </div>
          </div>

          <div class="form-row two-col">
            <div class="form-group">
              <label for="c-email">Email <span aria-hidden="true">*</span></label>
              <input type="email" id="c-email" name="email" placeholder="your@email.com" required />
            </div>
            <div class="form-group">
              <label for="c-phone">Phone</label>
              <input type="tel" id="c-phone" name="phone" placeholder="(xxx) xxx-xxxx" />
            </div>
          </div>

          <div class="form-group">
            <label for="c-message">Message <span aria-hidden="true">*</span></label>
            <textarea id="c-message" name="message" rows="5" placeholder="How can we help? Tell us about your child's age and when you'd like to start." required></textarea>
          </div>

          <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">
            Send Message
          </button>

          <p id="contact-success" style="display:none;color:var(--green);font-weight:600;text-align:center;margin-top:16px;padding:12px;background:var(--green-pale);border-radius:8px;">
            ✅ Thank you! We will get back to you as soon as possible.
          </p>
          <p id="contact-error" style="display:none;color:#c0392b;text-align:center;margin-top:16px;">
            Oops, there was an error. Please try again later.
          </p>
        </form>
      </div>

      <!-- CONTACT DETAILS -->
      <div class="contact-details">
        <div class="detail-card">
          <div class="detail-icon">📍</div>
          <h3>Find Us Here</h3>
          <address>
            2414 Virginia Road<br />
            Los Angeles, CA 90016
          </address>
        </div>

        <div class="detail-card">
          <div class="detail-icon">📞</div>
          <h3>Phone</h3>
          <p><a href="tel:3233307271">+1 (323) 330-7271</a></p>
        </div>

        <div class="detail-card">
          <div class="detail-icon">✉️</div>
          <h3>Email</h3>
          <p><a href="mailto:hello@wiseleadersacademy.com">hello@wiseleadersacademy.com</a></p>
        </div>

        <div class="detail-card">
          <div class="detail-icon">🕐</div>
          <h3>Hours</h3>
          <p>Monday – Friday<br />7:30 AM – 5:30 PM</p>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
.page-hero {
  background: linear-gradient(135deg, #f0f7f2, var(--cream));
  padding: 80px 0 64px;
  text-align: center;
}
.page-hero h1 { font-size: clamp(2rem, 5vw, 3.2rem); margin-bottom: 16px; }
.page-hero-sub { font-size: 1.1rem; color: var(--text-muted); max-width: 500px; margin: 0 auto; }

.contact-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 64px;
  align-items: start;
}

.contact-form-wrap h2 {
  font-size: 1.6rem;
  margin-bottom: 28px;
}

.form-row { margin-bottom: 0; }
.form-row.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

.form-group { margin-bottom: 20px; }
.form-group label {
  display: block;
  font-weight: 600;
  font-size: 14px;
  margin-bottom: 6px;
  color: var(--text);
}
.form-group label span { color: var(--green); }
.form-group input,
.form-group textarea {
  width: 100%;
  padding: 12px 16px;
  border: 1.5px solid #e0d8cc;
  border-radius: var(--radius-sm);
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  color: var(--text);
  background: var(--cream);
  transition: border-color 0.15s, box-shadow 0.15s;
  outline: none;
  resize: vertical;
}
.form-group input:focus,
.form-group textarea:focus {
  border-color: var(--green);
  box-shadow: 0 0 0 3px rgba(0,151,178,0.12);
}

.contact-details { display: flex; flex-direction: column; gap: 20px; }
.detail-card {
  background: var(--white);
  border-radius: var(--radius);
  padding: 24px 20px;
  box-shadow: var(--shadow);
}
.detail-icon { font-size: 24px; margin-bottom: 10px; }
.detail-card h3 { font-size: 1rem; margin-bottom: 8px; }
.detail-card p, .detail-card address {
  font-size: 14px;
  color: var(--text-muted);
  font-style: normal;
  line-height: 1.6;
  margin-bottom: 4px;
}
.detail-card a { color: var(--green); }
.detail-card a:hover { text-decoration: underline; }

@media (max-width: 900px) {
  .contact-grid { grid-template-columns: 1fr; gap: 40px; }
  .form-row.two-col { grid-template-columns: 1fr; }
}
</style>

<script>
const form = document.getElementById('contact-form') as HTMLFormElement | null;
const success = document.getElementById('contact-success');
const error = document.getElementById('contact-error');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
  btn.disabled = true;
  btn.textContent = 'Sending…';

  const data = new FormData(form);
  try {
    const res = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
    if (res.ok) {
      form.reset();
      if (success) success.style.display = 'block';
      if (error) error.style.display = 'none';
    } else {
      if (error) error.style.display = 'block';
    }
  } catch {
    if (error) error.style.display = 'block';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Send Message';
  }
});
</script>
