---
const purposes = {
  tour: "Schedule a Tour",
  tuition: "Inquire About Tuition",
  visit: "Schedule a Visit to See It in Person",
} as const;

const web3AccessKey = (
  import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ||
  import.meta.env.WEB3FORMS_ACCESS_KEY ||
  ''
).trim();
---

<div id="tour-modal" class="ms-modal" aria-hidden="true">
  <div class="ms-backdrop" data-ms-close="true" aria-hidden="true"></div>

  <div class="ms-panel" role="dialog" aria-modal="true" aria-labelledby="ms-title">
    <div class="ms-header">
      <div>
        <h3 id="ms-title" class="ms-title">Schedule a Tour</h3>
        <p class="ms-subtitle" id="ms-subtitle">
          Use the quick steps below to request a tour of our daycare.
        </p>
      </div>

      <button type="button" class="ms-close" data-ms-close="true" aria-label="Close modal">
        ✕
      </button>
    </div>

    <div class="ms-progress" aria-hidden="true">
      <span class="ms-dot" data-ms-step="1"></span>
      <span class="ms-dot" data-ms-step="2"></span>
      <span class="ms-dot" data-ms-step="3"></span>
    </div>

    <form id="ms-form" class="ms-form" action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value={web3AccessKey} />
      <input type="hidden" name="subject" value="Wise Leaders Academy - Multi-step inquiry" />
      <!-- Human-readable value set in JS when modal opens (shows clearly in Web3Forms emails) -->
      <input type="hidden" id="ms-purpose-input" name="purpose" value="" />

      <div class="ms-step" data-ms-step-index="0">
        <h4 class="ms-step-title">Step 1: Contact Info</h4>

        <label class="ms-label">
          Your name <span class="ms-req" aria-hidden="true">*</span>
          <input class="ms-input" name="name" type="text" required autocomplete="name" />
        </label>

        <label class="ms-label">
          Email <span class="ms-req" aria-hidden="true">*</span>
          <input class="ms-input" name="email" type="email" required autocomplete="email" />
        </label>

        <label class="ms-label">
          Phone
          <input class="ms-input" name="phone" type="tel" autocomplete="tel" />
        </label>

        <div class="ms-actions">
          <button type="button" class="ms-next" data-ms-next="true">Next</button>
        </div>
      </div>

      <div class="ms-step" data-ms-step-index="1" hidden>
        <h4 class="ms-step-title">Step 2: Child Details</h4>

        <label class="ms-label">
          Child's name
          <input class="ms-input" name="child_name" type="text" />
        </label>

        <label class="ms-label">
          Date of Birth (DOB) <span class="ms-req" aria-hidden="true">*</span>
          <input class="ms-input" name="dob" type="date" required />
        </label>

        <label class="ms-label">
          Preferred start date
          <input class="ms-input" name="start_date" type="date" />
        </label>

        <div class="ms-actions ms-between">
          <button type="button" class="ms-back" data-ms-back="true">Back</button>
          <button type="button" class="ms-next" data-ms-next="true">Next</button>
        </div>
      </div>

      <div class="ms-step" data-ms-step-index="2" hidden>
        <h4 class="ms-step-title">Step 3: Message & Preferences</h4>

        <label class="ms-label" for="ms-inquiry-text">
          What would you like to know about our Daycare? <span class="ms-req" aria-hidden="true">*</span>
        </label>
        <!-- Use `inquiry` (not `message`) so Web3Forms emails show the real parent text, not a misparsed label -->
        <textarea
          id="ms-inquiry-text"
          class="ms-input ms-textarea"
          name="inquiry"
          rows="4"
          required
          placeholder="A couple of details so we can help you faster…"
        ></textarea>

        <div class="ms-inline">
          <label class="ms-label ms-inline-label" for="ms-tour-slot">
            When would you like to tour our Daycare?
            <select id="ms-tour-slot" class="ms-input" name="tour_slot" required>
              <option value="Monday (1–2 PM)">On a Monday (1-2 PM)</option>
              <option value="Tuesday (1–2 PM)">On a Tuesday (1-2 PM)</option>
              <option value="Wednesday (1–2 PM)">On a Wednesday (1-2 PM)</option>
              <option value="Thursday (1–2 PM)">On a Thursday (1-2 PM)</option>
              <option value="Friday (1–2 PM)">On a Friday (1-2 PM)</option>
            </select>
          </label>
        </div>

        <p id="ms-form-error" class="ms-form-error" hidden>
          Something went wrong. Please try again or call us — we’d love to help.
        </p>
        <div class="ms-actions ms-between">
          <button type="button" class="ms-back" data-ms-back="true">Back</button>
          <button type="submit" class="ms-submit">Submit</button>
        </div>
      </div>

      <div class="ms-thanks" role="status" aria-live="polite" hidden>
        <div class="ms-thanks-card">
          <h4>Thanks!</h4>
          <p>We received your request. We’ll reach out soon.</p>
        </div>
      </div>
    </form>
  </div>
</div>

<style>
/* Matches site: teal accents, warm title, Playfair steps, surface-style panel */
.ms-modal {
  position: fixed;
  inset: 0;
  z-index: 2000;
  display: none;
}

.ms-modal[aria-hidden="false"] {
  display: block;
}

.ms-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(13, 58, 68, 0.45);
  backdrop-filter: blur(4px);
}

.ms-panel {
  position: relative;
  margin: 6vh auto 0;
  width: min(620px, calc(100vw - 32px));
  background: var(--white);
  border: 1px solid rgba(0, 151, 178, 0.14);
  border-radius: 22px 26px 24px 22px;
  box-shadow:
    0 20px 60px rgba(0, 151, 178, 0.18),
    0 0 0 1px rgba(255, 255, 255, 0.85) inset;
  padding: 22px 22px 20px;
  overflow: hidden;
}

.ms-panel::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--green) 0%, var(--accent-warm, #f07830) 100%);
  pointer-events: none;
}

.ms-header {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 16px;
  margin-bottom: 8px;
  padding-top: 4px;
  position: relative;
}

.ms-title {
  font-family: 'Playfair Display', serif;
  font-weight: 800;
  font-size: clamp(1.25rem, 3.5vw, 1.45rem);
  letter-spacing: -0.02em;
  color: var(--accent-warm, #f07830);
  margin: 0;
  text-align: center;
  line-height: 1.2;
}

.ms-subtitle {
  font-family: 'DM Sans', sans-serif;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text);
  margin: 8px 0 0;
  text-align: center;
}

.ms-close {
  position: absolute;
  right: 0;
  top: 0;
  border: 1px solid rgba(0, 151, 178, 0.2);
  background: var(--white);
  color: #3d4f5c;
  border-radius: 12px;
  padding: 8px 12px;
  cursor: pointer;
  font-size: 15px;
  line-height: 1;
  transition: background 0.15s, border-color 0.15s, color 0.15s;
}

.ms-close:hover {
  background: var(--green-pale);
  border-color: rgba(0, 151, 178, 0.35);
  color: var(--green);
}

.ms-progress {
  display: flex;
  gap: 8px;
  margin: 14px 0 18px;
  justify-content: center;
}

.ms-dot {
  width: 9px;
  height: 9px;
  border-radius: 999px;
  background: rgba(0, 151, 178, 0.2);
  border: 1px solid rgba(0, 151, 178, 0.12);
}

.ms-dot.is-active {
  background: var(--accent-warm, #f07830);
  border-color: rgba(240, 120, 48, 0.35);
}

.ms-form {
  margin: 0;
}

.ms-step-title {
  margin: 0 0 16px;
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--green);
  font-family: 'Playfair Display', serif;
  text-align: center;
  line-height: 1.25;
}

.ms-label {
  display: block;
  margin-bottom: 14px;
  font-weight: 600;
  font-size: 14px;
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
}

.ms-req {
  color: var(--accent-warm, #f07830);
}

.ms-input {
  display: block;
  width: 100%;
  margin-top: 8px;
  padding: 12px 14px;
  border-radius: var(--radius-sm);
  border: 1.5px solid rgba(0, 151, 178, 0.15);
  background: #fffdf9;
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  color: var(--text);
  transition: border-color 0.15s, box-shadow 0.15s;
  outline: none;
}

.ms-input:focus {
  border-color: var(--green);
  box-shadow: 0 0 0 3px rgba(0, 151, 178, 0.12);
}

.ms-textarea {
  resize: vertical;
  min-height: 100px;
}

.ms-inline {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.ms-inline-label {
  margin-bottom: 12px;
}

.ms-actions {
  margin-top: 16px;
  display: flex;
  justify-content: flex-end;
}

.ms-actions.ms-between {
  justify-content: space-between;
}

.ms-next {
  font-family: 'DM Sans', sans-serif;
  background: var(--green);
  border: 2px solid var(--green);
  color: var(--white);
  border-radius: 999px;
  padding: 12px 22px;
  font-weight: 700;
  font-size: 14px;
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s, transform 0.2s, box-shadow 0.2s;
}

.ms-next:hover {
  background: #007c92;
  border-color: #007c92;
  transform: translateY(-1px);
  box-shadow: var(--shadow);
}

.ms-back {
  font-family: 'DM Sans', sans-serif;
  background: transparent;
  border: 2px solid var(--green);
  color: var(--green);
  border-radius: 999px;
  padding: 10px 20px;
  font-weight: 700;
  font-size: 14px;
  cursor: pointer;
  transition: background 0.2s, color 0.2s, border-color 0.2s;
}

.ms-back:hover {
  background: var(--green-pale);
  color: #006f84;
  border-color: #006f84;
}

/* Step 1: Next matches the width of inputs (mobile + desktop). */
.ms-step[data-ms-step-index="0"] .ms-next {
  width: 100%;
}

.ms-step[data-ms-step-index="0"] .ms-actions {
  justify-content: center;
}

.ms-submit {
  font-family: 'DM Sans', sans-serif;
  background: var(--green);
  border: 2px solid var(--green);
  color: var(--white);
  border-radius: 999px;
  padding: 12px 22px;
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s, transform 0.2s, box-shadow 0.2s;
}

.ms-submit:hover {
  background: #007c92;
  border-color: #007c92;
  transform: translateY(-1px);
  box-shadow: var(--shadow);
}

.ms-form-error {
  color: #c0392b;
  font-size: 14px;
  font-weight: 600;
  margin: 0 0 12px;
  text-align: center;
}

.ms-thanks-card {
  background: linear-gradient(135deg, var(--green-pale) 0%, #ffffff 100%);
  border: 1px solid rgba(0, 151, 178, 0.15);
  border-radius: 18px 20px 18px 18px;
  padding: 22px 18px;
  text-align: center;
  box-shadow: 0 6px 24px rgba(0, 151, 178, 0.08);
}

.ms-thanks-card h4 {
  font-family: 'Playfair Display', serif;
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--green);
  margin: 0 0 8px;
}

.ms-thanks-card p {
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  color: var(--text-muted);
  margin: 0;
  line-height: 1.55;
}

@media (max-width: 700px) {
  .ms-panel {
    margin-top: 8vh;
    padding: 18px 16px 16px;
  }

  .ms-inline {
    grid-template-columns: 1fr;
  }

  .ms-actions {
    justify-content: center;
  }

  .ms-actions.ms-between {
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
  }
}
</style>

<script>
  const modal = document.getElementById('tour-modal');
  const form = document.getElementById('ms-form');
  const purposeInput = document.getElementById('ms-purpose-input');
  const steps = Array.from(modal?.querySelectorAll('.ms-step') ?? []);
  const dots = Array.from(modal?.querySelectorAll('.ms-dot') ?? []);
  const thanks = modal?.querySelector('.ms-thanks');
  const formError = document.getElementById('ms-form-error');

  let currentStepIndex = 0;
  function setActiveDot(index) {
    dots.forEach((d, i) => d.classList.toggle('is-active', i === index));
  }

  function showStep(index) {
    currentStepIndex = index;
    steps.forEach((s) => {
      const idx = Number(s.getAttribute('data-ms-step-index'));
      s.hidden = idx !== index;
    });
    setActiveDot(index);
    thanks && (thanks.hidden = true);
    formError && (formError.hidden = true);
  }

  function validateStep(stepEl) {
    const required = Array.from(stepEl.querySelectorAll('[required]'));
    for (const el of required) {
      if (!el.checkValidity()) {
        el.reportValidity();
        return false;
      }
    }
    return true;
  }

  function openModal(purpose) {
    if (!modal) return;
    const labels = {
      tour: 'Schedule a Tour',
      tuition: 'Inquire About Tuition',
      visit: 'Schedule a Visit to See It in Person',
    };
    purposeInput.value = labels[purpose] ?? purpose;

    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    showStep(0);

    // Focus first input for good UX.
    const first = steps[0]?.querySelector('input, select, textarea');
    first?.focus?.();
  }

  function closeModal() {
    if (!modal) return;
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  modal?.addEventListener('click', (e) => {
    const target = e.target;
    if (target && target.getAttribute && target.getAttribute('data-ms-close') === 'true') closeModal();
  });

  document.addEventListener('click', (e) => {
    const el = e.target?.closest?.('[data-modal-purpose]');
    if (!el) return;
    // If the trigger is an in-page hash link (href="#..."), allow the default
    // browser scroll so the user lands on the intended section.
    const href = (el.getAttribute('href') ?? '').trim();
    if (!href.startsWith('#')) e.preventDefault();
    e.stopPropagation();
    openModal(el.getAttribute('data-modal-purpose'));
  });

  modal?.addEventListener('click', (e) => {
    const nextBtn = e.target?.closest?.('[data-ms-next="true"]');
    const backBtn = e.target?.closest?.('[data-ms-back="true"]');
    if (nextBtn) {
      const stepEl = steps[currentStepIndex];
      if (!validateStep(stepEl)) return;
      showStep(Math.min(currentStepIndex + 1, steps.length - 1));
    } else if (backBtn) {
      showStep(Math.max(currentStepIndex - 1, 0));
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const stepEl = steps[currentStepIndex];
    if (!validateStep(stepEl)) return;

    const btn = form.querySelector('button[type="submit"], .ms-submit');
    if (btn) btn.disabled = true;
    formError && (formError.hidden = true);

    const fd = new FormData(form);
    const accessKey = String(fd.get('access_key') ?? '').trim();
    if (!accessKey) {
      if (formError) {
        formError.textContent = 'Form is not configured yet. Please call us while we finish setup.';
        formError.hidden = false;
      }
      if (btn) btn.disabled = false;
      return;
    }

    try {
      const res = await fetch(form.action, { method: 'POST', body: fd, headers: { Accept: 'application/json' } });
      const json = await res.json();
      if (!json.success) throw new Error(json.message || 'Request failed');
      form.reset();
      steps.forEach((s) => (s.hidden = true));
      thanks && (thanks.hidden = false);
      if (formError) {
        formError.textContent = 'Something went wrong. Please try again or call us — we’d love to help.';
      }
    } catch {
      formError && (formError.hidden = false);
    } finally {
      if (btn) btn.disabled = false;
    }
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>

