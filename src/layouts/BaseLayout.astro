---
import '../styles/global.css';
import '../styles/sections.css';
import MultiStepTourModal from '../components/MultiStepTourModal.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://lirp.cdn-website.com/2a45263c/dms3rep/multi/opt/wise-leaders-academy-logo-final-a4c1d616-1920w.png" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="https://lirp.cdn-website.com/2a45263c/dms3rep/multi/opt/wise-leaders-academy-fav-icon-1920w.png" />

  <!-- Fonts preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>

  <!-- ===== NAV (reference: airy white bar, centered links, right pill CTA) ===== -->
  <header id="site-header">
    <div class="container nav-inner">
      <a href="/" class="logo" aria-label="Wise Leaders Academy home">
        <img
          src="/brand/wila-logo.png"
          alt="Wise Leaders Academy"
          width="180"
          height="60"
        />
      </a>

      <nav id="main-nav" aria-label="Main navigation">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/gallery">Gallery</a></li>
          <li><a href="/contact">Contact Us</a></li>
        </ul>
      </nav>

      <a href="/#still-looking" class="header-cta">Get More Info</a>

      <button class="hamburger" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <MultiStepTourModal />

  <!-- ===== FOOTER ===== -->
  <footer>
    <div class="container footer-grid">
      <div class="footer-brand">
        <img
          src="/brand/footer-logo.png"
          alt="Wise Leaders Academy"
          width="180"
          height="60"
        />
        <p>Empowering children through play-based learning in an environment filled with love and kindness.</p>
      </div>

      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/understanding-daycare-costs-in-los-angeles-2025">How Much Does Daycare Cost In Los Angeles?</a></li>
          <li><a href="/contact">Contact Us</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Visit Us</h4>
        <address>
          2414 Virginia Road<br />
          Los Angeles CA, 90016
        </address>
        <p class="hours"><strong>Hours:</strong> Mon – Fri: 7:30 AM – 5:30 PM</p>
      </div>

      <div class="footer-col">
        <h4>Contact & License</h4>
        <ul>
          <li><a href="tel:3233307271">(323) 330-7271</a></li>
          <li><a href="mailto:hello@wiseleadersacademy.com">hello@wiseleadersacademy.com</a></li>
          <li>State License #197495535</li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Wise Leaders Academy. All Rights Reserved.</p>
      </div>
    </div>
  </footer>

</body>
</html>

<style>
/* ---- Header (light bar, sticky top) ---- */
#site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--white);
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 1px 0 rgba(0, 151, 178, 0.06), 0 4px 20px rgba(0, 0, 0, 0.04);
}

.nav-inner {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  align-items: center;
  column-gap: clamp(16px, 4vw, 40px);
  min-height: 64px;
  padding-block: 6px;
}

.logo img { height: 40px; width: auto; }

#main-nav { justify-self: center; }
#main-nav ul {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: clamp(2px, 1.5vw, 8px);
  list-style: none;
}
#main-nav a {
  padding: 6px 12px;
  border-radius: 8px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  font-size: 13px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #3d4f5c;
  transition: background 0.15s, color 0.15s;
}
#main-nav a:hover {
  background: var(--green-pale);
  color: var(--green);
}

.header-cta {
  justify-self: end;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--green);
  color: var(--white);
  padding: 8px 16px;
  border-radius: 999px;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  line-height: 1;
  border: 2px solid var(--green);
  transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.2s;
}
.header-cta:hover {
  background: #007c92;
  border-color: #007c92;
  color: var(--white);
}

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 4px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
  justify-self: end;
}
.hamburger span {
  display: block;
  width: 22px;
  height: 2px;
  background: #3d4f5c;
  border-radius: 2px;
  transition: transform 0.2s, opacity 0.2s;
}

/* ---- Footer ---- */
footer {
  background: linear-gradient(180deg, #1a3d47 0%, #0f2a30 100%);
  color: #ffffff;
  margin-top: 80px;
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px;
  padding: 64px 24px 48px;
}

.footer-brand img {
  margin-bottom: 16px;
  display: block;
  height: auto; /* Keep aspect ratio (logo is not square). */
}
.footer-brand p { font-size: 14px; line-height: 1.7; color: #ffffff; }

.footer-col h4 {
  font-family: 'Playfair Display', serif;
  font-size: 16px;
  color: rgba(253, 248, 240, 0.95);
  margin-bottom: 16px;
}

.footer-col ul { list-style: none; }
.footer-col ul li, .footer-col address, .footer-col .hours {
  font-size: 14px;
  color: #ffffff;
  margin-bottom: 8px;
  font-style: normal;
  line-height: 1.6;
}
.footer-col a { color: #ffffff; }
.footer-col a:hover { color: var(--green-light); }

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding: 20px 24px;
  text-align: center;
  font-size: 13px;
  color: #ffffff;
}

/* ---- Responsive ---- */
@media (max-width: 900px) {
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  .nav-phone { display: none; }
}

@media (max-width: 700px) {
  .nav-inner {
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    min-height: 0;
    row-gap: 0;
  }

  .logo {
    grid-column: 1;
    grid-row: 1;
  }
  .hamburger {
    display: flex;
    grid-column: 2;
    grid-row: 1;
  }
  .header-cta {
    display: none;
  }

  #main-nav {
    display: none;
    grid-column: 1 / -1;
    grid-row: 2;
    position: relative;
    top: auto;
    left: auto;
    right: auto;
    margin: 12px -24px 0;
    padding: 0 24px 16px;
    background: transparent;
    border-bottom: none;
    justify-self: stretch;
  }
  #main-nav.open {
    display: block;
  }
  #main-nav ul {
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    padding: 8px 0;
    background: var(--white);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow);
  }
  #main-nav a {
    display: block;
    padding: 12px 16px;
    border-radius: 0;
  }
  #main-nav li + li a {
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .nav-phone { display: none; }

  .footer-grid { grid-template-columns: 1fr; gap: 28px; }
}
</style>

<script>
const toggle = document.getElementById('nav-toggle');
const nav = document.getElementById('main-nav');
toggle?.addEventListener('click', () => {
  const open = nav?.classList.toggle('open');
  toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
});
</script>
